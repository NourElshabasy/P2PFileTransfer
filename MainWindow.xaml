<Window x:Class="P2PFileTransfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LAN P2P Transfer" Height="400" Width="350">
    <StackPanel Margin="20">
        
        <TextBlock Text="LAN File Transfer" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <GroupBox Header="Receive File" Padding="10">
            <StackPanel>
                <TextBlock Text="Click below to listen for incoming files:" Margin="0,0,0,5" Foreground="Gray"/>
                <Button x:Name="BtnReceive" Content="Start Receiving" Padding="5" Click="BtnReceive_Click"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Send File" Padding="10" Margin="0,15,0,0">
            <StackPanel>
                <TextBlock Text="Receiver's IP Address (Keep 127.0.0.1 for local testing):" Margin="0,0,0,5" Foreground="Gray"/>
                <TextBox x:Name="TxtIpAddress" Text="127.0.0.1" Padding="2" Margin="0,0,0,10"/>
                <Button x:Name="BtnSend" Content="Select File &amp; Send" Padding="5" Click="BtnSend_Click"/>
            </StackPanel>
        </GroupBox>

        <ProgressBar x:Name="TransferProgressBar" Height="20" Margin="0,20,0,10" Minimum="0" Maximum="100"/>
        <TextBlock x:Name="TxtStatus" Text="Status: Idle" HorizontalAlignment="Center" FontWeight="SemiBold"/>
        
    </StackPanel>
</Window>